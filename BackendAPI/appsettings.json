{
   "JwtSettings": {
    "SecretKey": " YOUR_SECRET_KEY_HERE_MINIMUM_32_CHARACTERS",
    "Issuer": "YOUR_ISSUER",
    "Audience": "YOUR_AUDIENCE",
    "ExpiryMinutes": 60
  },
  
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "server=localhost; database=YOUR_DATABASE_NAME; user=YOUR_USERNAME; password=YOUR_PASSWORD"
  }
}
